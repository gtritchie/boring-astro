# Cloudflare Web Analytics token — obtain from Cloudflare dashboard
# after adding boringbydesign.ca to Web Analytics. Leave unset locally.
PUBLIC_CF_WA_TOKEN=

# Optional Chrome override for pa11y-ci. Usually unnecessary:
# scripts/run-pa11y.mjs auto-detects system Chrome (macOS app bundle,
# Linux /usr/bin/google-chrome-stable, etc.). Set this only if your
# Chrome lives somewhere non-standard. In CI, the workflow installs
# Chrome via browser-actions/setup-chrome and sets this automatically.
PUPPETEER_EXECUTABLE_PATH=
