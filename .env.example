# Cloudflare Web Analytics token — obtain from Cloudflare dashboard
# after adding boringbydesign.ca to Web Analytics. Leave unset locally.
PUBLIC_CF_WA_TOKEN=

# Optional Chrome override for pa11y-ci. Usually unnecessary on macOS
# and Linux: scripts/run-pa11y.mjs uses chrome-launcher's cross-platform
# discovery (handles system app bundles, Snap/Flatpak, Windows Program
# Files, user-local installs). Set this only if auto-detection doesn't
# find your Chrome, or to pin a specific binary. If set, the value MUST
# point at a real file — run-pa11y fails loudly on a bad path rather
# than silently falling back. In CI, the workflow installs Chrome via
# browser-actions/setup-chrome and sets this automatically.
PUPPETEER_EXECUTABLE_PATH=
