# Supply-chain cooldown: never resolve a version published less than 7 days
# ago when (re)generating the lockfile. Most malicious npm releases are
# detected and yanked within hours to a few days, so this sidesteps the
# highest-risk window. Affects `npm install`/`npm update` only — `npm ci`
# installs straight from the committed lockfile and is unaffected.
min-release-age=7
