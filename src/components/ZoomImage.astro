---
// src/components/ZoomImage.astro — opt-in zoom overlay for in-article images.
// The image becomes a single-tab-stop button (corner magnifier badge) that
// opens a native <dialog> showing a full-resolution rendition scaled to fit
// ~90% of the viewport. Esc, the focus trap, and focus return are native
// <dialog> behavior.
import type { ImageMetadata } from "astro";
import { Image, getImage } from "astro:assets";

interface Props {
  src: ImageMetadata;
  alt: string;
}

const { src, alt } = Astro.props;

// Single full-native-width rendition for the overlay. layout "none" opts out
// of the global responsive srcset: the overlay <img> is one asset scaled by
// CSS, so extra breakpoint variants would be dead weight in the build output.
const fullSize = await getImage({ src, width: src.width, layout: "none" });
---

<figure class="zoom-image">
  <button type="button" class="zoom-image__trigger" aria-haspopup="dialog">
    <Image src={src} alt={alt} />
    <span class="zoom-image__badge" aria-hidden="true">
      <svg
        viewBox="0 0 24 24"
        width="18"
        height="18"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
      >
        <circle cx="10.5" cy="10.5" r="6.5"></circle>
        <line x1="15.3" y1="15.3" x2="21" y2="21"></line>
        <line x1="10.5" y1="7.5" x2="10.5" y2="13.5"></line>
        <line x1="7.5" y1="10.5" x2="13.5" y2="10.5"></line>
      </svg>
    </span>
    <span class="visually-hidden">(click to enlarge)</span>
  </button>
  <dialog class="zoom-image__dialog" aria-label={alt}>
    <img
      src={fullSize.src}
      alt={alt}
      width={src.width}
      height={src.height}
      loading="lazy"
      decoding="async"
    />
    <button type="button" class="zoom-image__close" aria-label="Close">
      <svg
        viewBox="0 0 24 24"
        width="18"
        height="18"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        aria-hidden="true"
      >
        <line x1="5" y1="5" x2="19" y2="19"></line>
        <line x1="19" y1="5" x2="5" y2="19"></line>
      </svg>
    </button>
  </dialog>
</figure>

<script>
  // One delegated listener, bound once to document, so it survives
  // ClientRouter navigations and covers every ZoomImage on the page.
  // Esc-to-close, the focus trap, and focus return are native <dialog>.
  document.addEventListener("click", (event) => {
    const target = event.target;
    if (!(target instanceof Element)) return;

    const trigger = target.closest(".zoom-image__trigger");
    if (trigger) {
      trigger.closest(".zoom-image")?.querySelector("dialog")?.showModal();
      return;
    }

    // Any click inside the open overlay — image, backdrop, or ✕ — closes it.
    const dialog = target.closest<HTMLDialogElement>("dialog.zoom-image__dialog");
    if (dialog?.open) dialog.close();
  });
</script>

<style>
  .zoom-image {
    /* Match the prose body-paragraph rhythm. */
    margin: var(--sp-4) 0;
  }

  .zoom-image__trigger {
    position: relative;
    display: block;
    width: fit-content;
    max-width: 100%;
    padding: 0;
    cursor: zoom-in;
  }

  .zoom-image__badge {
    position: absolute;
    right: 10px;
    bottom: 10px;
    display: grid;
    place-items: center;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    background: var(--accent);
    color: var(--bg);
  }

  .zoom-image__trigger:hover .zoom-image__badge,
  .zoom-image__trigger:focus-visible .zoom-image__badge {
    background: var(--fg);
  }

  .zoom-image__dialog {
    /* Sizing is driven by the img below; clear the UA's built-in caps. */
    max-width: none;
    max-height: none;
    padding: 0;
    border: none;
    background: none;
  }

  .zoom-image__dialog img {
    display: block;
    /* Fit within ~90% of the viewport; plain <img> sizing never upscales
       past the asset's native resolution. */
    max-width: 90vw;
    max-height: 90dvh;
    width: auto;
    height: auto;
  }

  /* Overlay chrome sits on the fixed dark backdrop in both themes, so the
     close button keeps theme-independent colors rather than tokens. */
  .zoom-image__close {
    position: absolute;
    top: 8px;
    right: 8px;
    display: grid;
    place-items: center;
    width: 36px;
    height: 36px;
    padding: 0;
    border-radius: 50%;
    background: rgb(0 0 0 / 0.6);
    color: #fff;
  }

  .zoom-image__dialog::backdrop {
    background: rgb(0 0 0 / 0.65);
  }

  /* The global reduced-motion rule in reset.css neutralizes this animation
     for users who prefer reduced motion. */
  .zoom-image__dialog[open] {
    animation: zoom-image-fade 150ms ease-out;
  }
  @keyframes zoom-image-fade {
    from {
      opacity: 0;
    }
  }

  /* Lock background scroll while an overlay is open. */
  :global(html:has(dialog.zoom-image__dialog[open])) {
    overflow: hidden;
  }
</style>
