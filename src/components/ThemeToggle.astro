---
// src/components/ThemeToggle.astro — radio group: Light / Dark / System; persists to localStorage
---

<fieldset class="theme-toggle">
  <legend class="visually-hidden">Theme</legend>
  <label class="theme-option">
    <input type="radio" name="theme-choice" value="light" data-theme-radio />
    <span>Light <span aria-hidden="true">☀︎</span></span>
  </label>
  <label class="theme-option">
    <input type="radio" name="theme-choice" value="dark" data-theme-radio />
    <span>Dark <span aria-hidden="true">☾</span></span>
  </label>
  <label class="theme-option">
    <input type="radio" name="theme-choice" value="system" data-theme-radio />
    <span>System <span aria-hidden="true">⌘</span></span>
  </label>
</fieldset>

<style>
  .theme-toggle {
    display: inline-flex;
    border: 1px solid var(--border-ui);
    border-radius: 4px;
    padding: 0;
    margin: 0;
    min-inline-size: 0; /* override fieldset default */
  }
  .theme-option {
    cursor: pointer;
    display: inline-flex;
  }
  .theme-option > input {
    /* Visually hide but keep focusable; the label span carries the visual. */
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    clip-path: inset(50%);
    white-space: nowrap;
  }
  .theme-option > span {
    display: inline-block;
    padding: 0.3rem 0.65rem;
    font-size: 0.82rem;
    letter-spacing: 0.02em;
    color: var(--fg);
    background: var(--btn-bg);
  }
  .theme-option:first-of-type > span {
    border-top-left-radius: 3px;
    border-bottom-left-radius: 3px;
  }
  .theme-option:last-of-type > span {
    border-top-right-radius: 3px;
    border-bottom-right-radius: 3px;
  }
  .theme-option + .theme-option > span {
    border-left: 1px solid var(--border-ui);
  }
  .theme-option:hover > span {
    background: var(--border);
  }
  .theme-option > input:checked + span {
    background: var(--fg);
    color: var(--bg);
  }
  .theme-option > input:focus-visible + span {
    outline: 2px solid var(--fg);
    outline-offset: 2px;
  }
</style>

<script>
  // Survives Astro View Transitions: change handler is attached once to
  // `document` via delegation, and radio sync runs on both initial load
  // and every `astro:page-load` event after navigation.
  type Choice = "light" | "dark" | "system";
  const INIT_FLAG = "__bbdThemeToggleReady";

  function currentFromDom(): Choice {
    // The DOM is the source of truth when storage is unavailable: the
    // inline bootstrap in <head> and applyTheme() both write data-theme,
    // so reading it back gives the live state without persistence.
    const v = document.documentElement.dataset["theme"];
    return v === "light" || v === "dark" ? v : "system";
  }

  function read(): Choice {
    // localStorage can throw (SecurityError in strict privacy modes,
    // sandboxed iframes, etc.) — fall back to the DOM so the radios
    // and applied theme keep tracking the actual state.
    try {
      const v = localStorage.getItem("theme");
      return v === "light" || v === "dark" || v === "system" ? v : currentFromDom();
    } catch {
      return currentFromDom();
    }
  }

  function applyTheme(choice: Choice) {
    if (choice === "system") {
      document.documentElement.removeAttribute("data-theme");
    } else {
      document.documentElement.setAttribute("data-theme", choice);
    }
    try {
      localStorage.setItem("theme", choice);
    } catch {
      // Persistence unavailable — theme applies for this page load only.
    }
    syncRadios(choice);
  }

  function syncRadios(choice: Choice) {
    for (const el of document.querySelectorAll<HTMLInputElement>("[data-theme-radio]")) {
      el.checked = el.value === choice;
    }
  }

  function initOnce() {
    const w = window as unknown as Record<string, unknown>;
    if (w[INIT_FLAG]) return;
    w[INIT_FLAG] = true;
    // Delegated change — survives any DOM swap because it lives on document.
    document.addEventListener("change", (e) => {
      const target = e.target as HTMLInputElement | null;
      if (!target?.matches("[data-theme-radio]")) return;
      const v = target.value;
      if (v === "light" || v === "dark" || v === "system") applyTheme(v);
    });
    // Per-page radio sync after View Transitions. Registered exactly once
    // because initOnce is guarded by INIT_FLAG.
    document.addEventListener("astro:page-load", () => syncRadios(read()));
  }

  // First paint (inline theme bootstrap in <head> has already set data-theme).
  initOnce();
  syncRadios(read());
</script>
