{
  "name": "boring-astro",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "wrangler dev",
    "preview:astro": "astro build && astro preview --host 127.0.0.1 --port 4321",
    "check": "astro check && prettier --check . && eslint .",
    "pa11y": "node scripts/run-pa11y.mjs",
    "lighthouse": "astro build && lhci autorun",
    "link-check": "bash scripts/run-link-check.sh"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/cloudflare": "^13.2.1",
    "@astrojs/mdx": "^5.0.4",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "astro": "^6.1.9"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "eslint": "^10.2.1",
    "eslint-plugin-astro": "^1.7.0",
    "pa11y-ci": "^4.1.0",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.0",
    "wait-on": "^9.0.5",
    "wrangler": "^4.85.0"
  }
}
