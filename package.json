{
  "name": "boring-astro",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "wrangler dev",
    "preview:astro": "astro build && astro preview --host 127.0.0.1 --port 4321",
    "check": "astro check && prettier --check . && eslint .",
    "format": "prettier --write .",
    "pa11y": "node scripts/run-pa11y.mjs",
    "lighthouse": "astro build && lhci autorun",
    "link-check": "bash scripts/run-link-check.sh"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/cloudflare": "^13.6.1",
    "@astrojs/mdx": "^6.0.2",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@open-adventure/core": "^1.0.2",
    "astro": "^6.4.4"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "eslint": "^10.4.1",
    "eslint-plugin-astro": "^1.7.0",
    "pa11y-ci": "^4.1.0",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "unist-util-visit": "^5.1.0",
    "wrangler": "^4.98.0"
  }
}
