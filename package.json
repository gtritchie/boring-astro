{
  "name": "boring-astro",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "engines": {
    "node": ">=24.16.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "wrangler dev",
    "preview:astro": "astro build && astro preview --host 127.0.0.1 --port 4321",
    "check": "astro check && prettier --check . && eslint .",
    "format": "prettier --write .",
    "pa11y": "node scripts/run-pa11y.mjs",
    "lighthouse": "astro build && lhci autorun",
    "link-check": "bash scripts/run-link-check.sh"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/cloudflare": "^14.1.3",
    "@astrojs/markdown-remark": "^7.2.1",
    "@astrojs/mdx": "^7.0.3",
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "@open-adventure/core": "^1.0.2",
    "astro": "^7.1.1"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "eslint": "^10.7.0",
    "eslint-plugin-astro": "^3.0.1",
    "pa11y-ci": "^4.1.1",
    "prettier": "^3.9.5",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.64.0",
    "unist-util-visit": "^5.1.0",
    "wrangler": "^4.112.0"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "fsevents@2.3.3": true,
    "puppeteer@24.42.0": true,
    "sharp@0.34.5": true,
    "workerd@1.20260714.1": true
  }
}
